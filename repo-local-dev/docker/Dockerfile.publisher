# ─────────────────────────────────────────────────────────────────────────────
# AMPS Publisher image — separate from agentic-ai:latest so the entrypoint
# can be set to python without affecting agent containers.
#
# Build (from repo-local-dev/):
#   docker build -f docker/Dockerfile.publisher -t agentic-ai-publisher:latest .
# ─────────────────────────────────────────────────────────────────────────────

FROM agentic-ai:latest

# Copy AMPS publisher scripts into /app/scripts/
# Avoids bind-mounting individual files, which fails on Windows VDI.
COPY scripts/amps_publisher.py /app/scripts/amps_publisher.py
COPY scripts/product_publishers.py /app/scripts/product_publishers.py

# Override entrypoint — publishers run python directly, not entrypoint.sh
ENTRYPOINT ["python"]
