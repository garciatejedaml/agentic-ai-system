# ── Agentic AI System — Environment Variables ─────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "anthropic" = Anthropic API (best quality, requires API key below)
# "ollama"    = Local Ollama (free, no API key needed — see Ollama section below)
# "bedrock"   = AWS Bedrock (production, no API key — uses IAM role)
# "mock"      = Canned responses (no LLM needed — for infra testing / CI)
LLM_PROVIDER=anthropic

# ── Anthropic API (LLM_PROVIDER=anthropic) ────────────────────────────────────
# Get a key at https://console.anthropic.com
# Not needed if LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (defaults to latest Sonnet + Haiku)
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ── Mock LLM (LLM_PROVIDER=mock) — no API key, canned responses ──────────────
# Use for infra validation, CI pipelines, and demo environments.
# All services start and the full agent pipeline runs — responses are placeholder text.
# Switch to bedrock (or anthropic) once the API key / IAM role is approved.

# ── Demo mode — pre-scripted financial responses for presentations ─────────────
# Intercepts matching queries at the API layer and returns realistic scripted
# responses without any LLM call. Unmatched queries fall through to LLM_PROVIDER.
#
# Recommended setup for corporate machines (no API key, no internet required):
#   DEMO_MODE_ENABLED=true
#   LLM_PROVIDER=ollama      ← real intelligence for off-script questions
#   OLLAMA_MODEL=llama3.2:3b ← install Ollama first: brew install ollama
#
# Minimal setup (no Ollama either):
#   DEMO_MODE_ENABLED=true
#   LLM_PROVIDER=mock        ← generic fallback for unscripted queries
#
# Demo scenarios covered (keyword matched, case-insensitive):
#   "portfolios" / "list portfolios"  → portfolio overview table
#   "hy" / "high yield" / "hy_main"   → HY_MAIN holdings
#   "ig" / "investment grade"          → IG_CORE holdings
#   "em" / "emerging"                  → EM_BLEND exposure
#   "cds" / "spread" / "credit"        → CDS spread table
#   "rfq" / "trader" / "hit rate"      → KDB trading analytics
#   "etf" / "flow"                     → ETF flow data
#   "var" / "risk" / "dv01"            → Risk & P&L dashboard
#   "rates" / "treasury" / "rates_gov" → RATES_GOV holdings
#   "help" / "capabilities" / "demo"   → system overview
#
# DEMO_MODE_ENABLED=false

# ── Ollama (LLM_PROVIDER=ollama) — free, no API key required ──────────────────
# Install on Mac: brew install ollama && ollama serve
# Pull a model:   ollama pull llama3.2:3b
#
# Docker containers reach native Ollama via host.docker.internal (set automatically).
# Switch to http://ollama:11434 only when using the Docker Ollama profile.
#
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_FAST_MODEL=

# ── Bedrock (LLM_PROVIDER=bedrock) — AWS production, no API key needed ────────
# Requires an ECS task role (or EC2 instance profile) with bedrock:InvokeModel.
# Model defaults are the latest Sonnet + Haiku cross-region inference profiles.
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6-20251101-v1:0
# BEDROCK_FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── Optional: Dynatrace (enterprise APM — recommended for JP Morgan prod) ──────
# Dynatrace receives all OTel spans natively alongside Phoenix/Langfuse.
# Set OBSERVABILITY_ENABLED=true and fill in the values below.
# No extra SDK needed — uses the same opentelemetry-exporter-otlp-proto-http.
# DYNATRACE_ENDPOINT=https://{your-env-id}.live.dynatrace.com
# DYNATRACE_API_TOKEN=dt0c01....

# ── Optional: observability (Langfuse) ────────────────────────────────────────
# Leave empty to disable tracing (OBSERVABILITY_ENABLED defaults to false)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Optional: web search tool ─────────────────────────────────────────────────
# Get a free key at https://brave.com/search/api/
BRAVE_API_KEY=

# ── Phase 4: Guardrails ────────────────────────────────────────────────────────
# Max tool-use loop iterations per Strands agent (prevents runaway tool chains)
# AGENT_MAX_ITERATIONS=15
# LangGraph cycle guard (maximum nodes traversed before aborting)
# GRAPH_RECURSION_LIMIT=25
# Per-agent A2A timeouts in seconds (tuned per data-source latency profile)
# AGENT_TIMEOUT_DEFAULT=60
# AGENT_TIMEOUT_KDB=90      # KDB parquet scans can be slow
# AGENT_TIMEOUT_AMPS=30     # AMPS is real-time, must respond fast
# AGENT_TIMEOUT_RISK_PNL=90 # VaR computation is CPU-intensive
# Daily request rate limit per user (backed by DynamoDB token-usage table)
# RATE_LIMIT_ENABLED=true
# DAILY_REQUEST_LIMIT=1000

# ── Optional: AMPS product topic host overrides ───────────────────────────────
# Only needed if you run AMPS instances outside Docker (e.g. native AMPS install).
# When using docker-compose.local.yml these are set automatically.
# AMPS_PORTFOLIO_HOST=localhost
# AMPS_PORTFOLIO_PORT=9008
# AMPS_CDS_HOST=localhost
# AMPS_CDS_PORT=9009
# AMPS_ETF_HOST=localhost
# AMPS_ETF_PORT=9010
# AMPS_RISK_HOST=localhost
# AMPS_RISK_PORT=9011
